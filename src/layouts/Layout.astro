---
import { ClientRouter } from "astro:transitions";
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import LanguageBanner from "@components/language-banner.astro";

import "@fontsource-variable/inter/index.css";

export interface Props {
  title?: string;
  description?: string;
  footerMargin?: boolean;
  navbar?: typeof Navbar;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site,
).toString();

const { title, description: customDescription, footerMargin = true, navbar: CustomNavbar } = Astro.props;
const NavbarComponent = CustomNavbar || Navbar;

const makeTitle = title
  ? title + " | " + "DealDroid"
  : "DealDroid - No-Code Chatbot for Quality Sellers";

const lang = Astro.currentLocale || "en";

const description =
  customDescription ||
  "DealDroid - No-Code Chatbot for Quality Sellers. Engage visitors, capture leads, and boost conversions with our easy-to-use chatbot platform.";

const enUrl = new URL(Astro.url.pathname.replace(/^\/th/, ""), Astro.site).toString();
const thUrl = new URL("/th" + Astro.url.pathname.replace(/^\/th/, ""), Astro.site).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "DealDroid Homepage Screenshot",
        },
        optional: {
          description: description,
        },
      }}
    />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="th" href={thUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }

      /* Medium-style HR with three dots */
      .prose hr {
        border: none !important;
        background: none !important;
        text-align: center;
        margin-top: 56px !important;
        margin-bottom: 56px !important;
        height: auto !important;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .prose hr::before {
        content: "• • •";
        font-size: 12px;
        letter-spacing: 0.8em;
        color: rgba(0, 0, 0, 0.5);
        font-weight: 400;
      }
    </style>
    <!-- Google Analytics -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-Q8KNW432RV"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-Q8KNW432RV");
    </script>
    <ClientRouter />
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
      defer></script>
    <link
      rel="stylesheet"
      href="https://happyhead.dealdroid.net/assets/index.css"
    />
  </head>
  <body>
    <LanguageBanner />
    <NavbarComponent />
    <slot />
    <Footer margin={footerMargin} />
    <script is:inline>
      // @ts-ignore
      window.ChatHeadConfig = {
        scriptId: "script_xaugxgesi6a",
        title: "Ask DealDroid",
        openTitle: "How can we help you?",
        theme: {
          primary: "#4f46e5",
        },
        openQuestions: [
          "What is DealDroid?",
          "How to integrate DealDroid?",
          "Pricing details",
        ],
      };
    </script>
    <script
      type="module"
      src="https://happyhead.dealdroid.net/assets/index.js?scriptId=script_xaugxgesi6a"
    ></script>
  </body>
</html>
