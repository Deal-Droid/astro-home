---
/**
 * ChatSimulation - Reusable animated chat mockup component.
 * Supports multiple conversation sets that cycle with fade transitions.
 *
 * Props:
 *   storeName: string — Chat header store name
 *   conversations: Array<Array<{ sender: 'bot' | 'customer', text: string }>> — Multiple conversation sets
 *   typingDelay?: number — ms between messages (default 3000)
 *   pauseBetween?: number — ms pause between conversation sets (default 6000)
 *   theme?: 'default' | 'whatsapp' — Visual theme (default 'default')
 *   loop?: boolean — Whether to loop conversations (default true)
 */
import dji13storeLogo from "@assets/brands/dji13store-BW.png";
import techgearLogo from "@assets/brands/TechGear.png";
import mochiLogo from "@assets/brands/mochi.jpg";
import type { Message } from "@utils/chat-simulation";
import ChatHeader from "./chat-header.astro";
import ChatMessages from "./chat-messages.astro";
import ChatInputBar from "./chat-input-bar.astro";

interface Props {
  storeName: string;
  conversations: Message[][];
  typingDelay?: number;
  pauseBetween?: number;
  theme?: "default" | "whatsapp";
  loop?: boolean;
}

const {
  storeName,
  conversations,
  typingDelay = 3000,
  pauseBetween = 6000,
  theme = "default",
  loop = true,
} = Astro.props;

const isWhatsapp = theme === "whatsapp";

const storeLogo =
  storeName === "DJI 13 Store"
    ? dji13storeLogo.src
    : storeName === "TechGear SG"
      ? techgearLogo.src
      : storeName === "Mochi"
        ? mochiLogo.src
        : "/favicon.svg";
---

<div
  class:list={[
    "chat-simulation flex flex-col rounded-2xl shadow-2xl overflow-hidden max-w-sm w-full h-[530px]",
    isWhatsapp ? "border border-slate-200" : "bg-white border border-slate-200",
  ]}
  data-delay={typingDelay}
  data-pause={pauseBetween}
  data-theme={theme}
  data-conversations={JSON.stringify(conversations)}
  data-logo={storeLogo}
  data-store-name={storeName}
  data-loop={loop ? "true" : "false"}>
  <ChatHeader theme={theme} storeName={storeName} storeLogo={storeLogo} />
  <ChatMessages theme={theme} storeName={storeName} storeLogo={storeLogo} />
  <ChatInputBar theme={theme} />
</div>

<style is:global>
  .chat-messages {
    transition: opacity 0.4s ease;
  }
  .chat-messages.fading {
    opacity: 0;
  }

  .chat-bubble {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.35s ease-out,
      transform 0.35s ease-out;
  }
  .chat-bubble.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .chat-typing {
    opacity: 0;
    transition: opacity 0.25s ease-out;
  }
  .chat-typing.active {
    opacity: 1;
  }

  .typing-dot {
    animation: typingBounce 1.4s infinite ease-in-out;
  }
  .typing-dot:nth-child(1) {
    animation-delay: 0s;
  }
  .typing-dot:nth-child(2) {
    animation-delay: 0.2s;
  }
  .typing-dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes typingBounce {
    0%,
    60%,
    100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    30% {
      transform: translateY(-4px);
      opacity: 1;
    }
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  import { initChatSimulations } from "@utils/chat-simulation";
  document.addEventListener("DOMContentLoaded", initChatSimulations);
  document.addEventListener("astro:page-load", initChatSimulations);
</script>
