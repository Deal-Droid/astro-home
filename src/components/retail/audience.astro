---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";

const page_ui: UILanguages = {
  en: {
    "aud.badge": "Who Is This For",
    "aud.heading": "We're selective — so every client gets real results",
    "aud.desc":
      "DealDroid isn't your average chatbot — we're built for businesses ready to scale sales through chat",
    "aud.fit_title": "Great Fit If You",
    "aud.fit1": "Running paid ads (Meta, Google, TikTok) with $1K+/month spend",
    "aud.fit2": "Selling via Messenger, WhatsApp, Instagram, Shopee, or Lazada",
    "aud.fit3":
      "Have a chat team but response quality or speed isn't good enough",
    "aud.fit4":
      "Looking for AI tools that actually boost revenue and efficiency",
    "aud.fit5":
      "Struggling with chat volume spikes during campaigns or sales events",
    "aud.fit6":
      "Want to serve multilingual customers (English, Mandarin, Malay, etc.)",
    "aud.not_title": "Not a Fit If",
    "aud.not1": "Don't sell through chat channels at all",
    "aud.not2": "Ad spend under $1,000/month",
    "aud.not3":
      "Looking for a basic scripted chatbot that can only follow fixed flows",
    "aud.cta": "Get Free Inbox Audit — Consult Before You Decide",
    "aud.cta_link": "https://cal.com",
    "aud.sub1": "AI starts selling in your inbox within 48 hours after onboarding",
    "aud.sub2": "Our AI Expert team handles the full setup for you",
  },
  th: {
    "aud.badge": "เหมาะสำหรับธุรกิจประเภทใด",
    "aud.heading": "เราเลือกลูกค้า เพื่อให้ผลลัพธ์ชัดเจนทุกราย",
    "aud.desc":
      "DealDroid ไม่ใช่ chatbot ทั่วไป — เราออกแบบให้เหมาะกับธุรกิจที่พร้อม scale ยอดขายผ่านแชท",
    "aud.fit_title": "เหมาะกับร้านที่",
    "aud.fit1": "Facebook Page 50K followers ขึ้นไป",
    "aud.fit2": "Run Ads มากกว่า 50,000 บาท/เดือน",
    "aud.fit3": "ใช้ Messenger, LINE OA, Instagram หรือ Website เป็นช่องทางขาย",
    "aud.fit4": "มี Admin ตอบแชทอยู่แล้ว แต่คุณภาพการตอบยังไม่ดีพอ",
    "aud.fit5":
      "ธุรกิจที่มองหา AI Tools ที่ boost ยอดขาย และ efficiency ได้จริง",
    "aud.fit6": "เจอปัญหารับแชทช้าหรือ หลุดในช่วง campaign peak",
    "aud.not_title": "ไม่เหมาะถ้า",
    "aud.not1": "ไม่มี chat inbox หรือไม่ได้ขายผ่านแชท",
    "aud.not2": "Ad spend ต่ำกว่า 50,000 บาท/เดือน",
    "aud.not3": 'ต้องการ "chatbot ราคาถูก" ทั่วไป ที่ตอบได้แค่ตามที่กำหนด',
    "aud.cta": "นัดคุยวิเคราะห์ Inbox ฟรี — ปรึกษาก่อนตัดสินใจ",
    "aud.cta_link": "https://line.me/R/ti/p/@dealdroid",
    "aud.sub1": "AI เริ่มขายจริงใน inbox ของคุณภายใน 48 ชั่วโมงหลังตัดสินใจ",
    "aud.sub2": "ทีมงาน AI Expert พร้อม Setup ให้ทั้งหมด",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);

const fitCriteria = [
  p("aud.fit1"),
  p("aud.fit2"),
  p("aud.fit3"),
  p("aud.fit4"),
  p("aud.fit5"),
  p("aud.fit6"),
];

const notFit = [p("aud.not1"), p("aud.not2"), p("aud.not3")];
---

<section class="py-16 sm:py-24 bg-slate-50 overflow-hidden">
  <Container>
    <!-- Badge -->
    <span class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1.5 rounded-full mb-4">
      {p("aud.badge")}
    </span>

    <!-- Heading & Description -->
    <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mb-3">
      {p("aud.heading")}
    </h2>
    <p class="text-xl text-slate-500 mb-10 max-w-2xl">
      {p("aud.desc")}
    </p>

    <!-- Two Columns -->
    <div class="grid sm:grid-cols-2 gap-6 mb-12">
      <!-- Great Fit -->
      <div class="relative overflow-hidden bg-white rounded-2xl shadow-lg border border-teal-200">
        <div class="bg-teal-50 px-6 py-4 flex items-center gap-3 border-b border-teal-100">
          <div class="w-9 h-9 rounded-full bg-teal-100 flex items-center justify-center">
            <Icon name="ph:check-circle-fill" class="w-5 h-5 text-teal-600" />
          </div>
          <h3 class="font-bold text-slate-900 text-xl">
            {p("aud.fit_title")}
          </h3>
        </div>
        <ul class="p-6 space-y-4">
          {
            fitCriteria.map((item) => (
              <li class="flex items-start gap-3 text-slate-600 text-lg leading-relaxed">
                <span class="mt-1 shrink-0 w-6 h-6 rounded-full bg-teal-50 flex items-center justify-center">
                  <Icon name="ph:check-circle-fill" class="w-4 h-4 text-teal-600" />
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Not a Fit -->
      <div class="relative overflow-hidden bg-white rounded-2xl shadow-lg border border-red-200">
        <div class="bg-red-50 px-6 py-4 flex items-center gap-3 border-b border-red-100">
          <div class="w-9 h-9 rounded-full bg-red-100 flex items-center justify-center">
            <Icon name="ph:x-circle-fill" class="w-5 h-5 text-red-500" />
          </div>
          <h3 class="font-bold text-slate-900 text-xl">
            {p("aud.not_title")}
          </h3>
        </div>
        <ul class="p-6 space-y-4">
          {
            notFit.map((item) => (
              <li class="flex items-start gap-3 text-slate-600 text-lg leading-relaxed">
                <span class="mt-1 shrink-0 w-6 h-6 rounded-full bg-red-50 flex items-center justify-center">
                  <Icon name="ph:x-circle-fill" class="w-4 h-4 text-red-500" />
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center space-y-4">
      <Link href={p("aud.cta_link")} size="lg" style="primary">
        {p("aud.cta")}
      </Link>
      <p class="text-lg text-slate-500">{p("aud.sub1")}</p>
      <p class="text-lg text-slate-500">{p("aud.sub2")}</p>
    </div>
  </Container>
</section>
