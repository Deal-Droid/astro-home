---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";
import djiScreenshot from "@assets/customer/dji13store-facebook.png";
import messengerSvg from "@assets/channels/messenger.svg";
import lineSvg from "@assets/channels/line.svg";
import websiteSvg from "@assets/channels/website.svg";

const page_ui: UILanguages = {
  en: {
    "cs.badge": "Real Results · Case Study",
    "cs.heading": 'Not just "trying AI"',
    "cs.subheading": "These are real results from month one",
    "cs.store_desc":
      "A leading drone retailer used DealDroid to handle Facebook Ads traffic across Messenger, LINE, and web chat — here's what happened in 30 days.",
    "cs.store_type": "🏪 Authorized Drone Dealer",
    "cs.store_detail":
      "Multi-channel retail store selling premium electronics. Running significant Facebook & Google Ads with high daily chat volume across Messenger and website.",
    "cs.result_heading":
      "In the first month with DealDroid, AI handled 90%+ of all customer chats",
    "cs.stat1_value": "2,930",
    "cs.stat1_label": "Customers handled by DealDroid AI",
    "cs.stat2_value": "80%",
    "cs.stat2_label": "Resolved by AI — no human needed",
    "cs.stat3_value": "10%",
    "cs.stat3_label": "Qualified & handed to team to close",
    "cs.stat4_value": "24/7",
    "cs.stat4_label": "Coverage when staff is offline",
    "cs.stat_summary": "Handled all ad traffic without hiring additional staff",
    "cs.cta": "See the Full Case Study in Your Free Inbox Audit",
    "cs.cta_link": "https://cal.com",
    "cs.channels": "Messenger · Website",
  },
  th: {
    "cs.badge": "Real Results · Case Study",
    "cs.heading": 'ไม่ใช่แค่ "ลองใช้ AI"',
    "cs.subheading": "นี่คือผลลัพธ์จริงใน 1 เดือน",
    "cs.store_desc":
      "ร้านค้าขาย Drone ชั้นนำในไทย ระดับเดียวกับร้านที่คุณใช้ DealDroid รับมือ traffic จาก Facebook Ads ในเดือน พ.ย 2025",
    "cs.store_type": "Authorized DJI Drones Dealer in Thailand",
    "cs.store_detail": "",
    "cs.result_heading":
      "เดือนแรกที่ใช้ DealDroid<br>AI ตอบลูกค้าแทน Admin ให้มากกว่า 90%",
    "cs.stat1_value": "2,930",
    "cs.stat1_label": "ลูกค้าที่ DealDroid AI ตอบให้ทั้งหมด",
    "cs.stat2_value": "80%",
    "cs.stat2_label": "AI จบให้แบบไม่ต้องให้คนช่วย",
    "cs.stat3_value": "10%",
    "cs.stat3_label": "AI กรองแล้วส่งต่อให้คนช่วยปิด",
    "cs.stat4_value": "24/7",
    "cs.stat4_label": "ดูแลลูกค้าให้ในเมื่อ admin ไม่อยู่",
    "cs.stat_summary": "ช่วยรับทราฟฟิกจากแอดได้ โดยไม่ต้องเพิ่มแอดมิน",
    "cs.cta": "ขอดูรายละเอียด Full Case Study ใน ช่วงนัดคุยวิเคราะห์ Inbox",
    "cs.cta_link": "https://line.me/R/ti/p/@dealdroid",
    "cs.channels": "Messenger · LINE · Website",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);

const channels = [
  { name: "Messenger", icon: messengerSvg.src },
  { name: "LINE", icon: lineSvg.src },
  { name: "Website", icon: websiteSvg.src },
];

const stats = [
  {
    value: p("cs.stat1_value"),
    label: p("cs.stat1_label"),
    icon: "fluent:people-team-24-regular",
  },
  {
    value: p("cs.stat2_value"),
    label: p("cs.stat2_label"),
    icon: "fluent:bot-24-regular",
  },
  {
    value: p("cs.stat3_value"),
    label: p("cs.stat3_label"),
    icon: "fluent:people-settings-24-regular",
  },
  {
    value: p("cs.stat4_value"),
    label: p("cs.stat4_label"),
    icon: "fluent:clock-24-regular",
  },
];
---

<section id="proof" class="bg-slate-50 py-16 sm:py-24">
  <Container>
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-10">
      <span
        class="inline-block bg-teal-50 border border-teal-200 text-teal-700 text-xs font-semibold px-4 py-1.5 rounded-full mb-4"
      >
        {p("cs.badge")}
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-2">
        {p("cs.heading")}
      </h2>
      <p class="text-xl font-bold text-slate-700 mb-2">
        {p("cs.subheading")}
      </p>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        {p("cs.store_desc")}
      </p>
    </div>

    <!-- Main Card -->
    <div
      class="rounded-2xl border-2 border-teal-200 bg-teal-50/30 p-6 sm:p-10"
    >
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-center">
        <!-- Left Column: Store Image + Channels -->
        <div class="lg:col-span-2">
          <p class="text-sm font-medium text-slate-500 mb-3">
            {p("cs.store_type")}
          </p>
          <div class="rounded-xl overflow-hidden shadow-lg border border-slate-200/50">
            <Image
              src={djiScreenshot}
              alt="DJI 13 Store Facebook Page"
              class="w-full"
              loading="lazy"
            />
          </div>
          <div class="flex items-center gap-4 mt-3">
            {
              channels.map((ch) => (
                <div class="flex items-center gap-1.5">
                  <img
                    src={ch.icon}
                    alt={ch.name}
                    class="w-4 h-4 shrink-0 object-contain"
                  />
                  <span class="text-sm text-slate-500">{ch.name}</span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Right Column: Results + Stats -->
        <div class="lg:col-span-3">
          <h3
            class="text-xl sm:text-2xl md:text-3xl font-bold text-slate-900 mb-8"
            set:html={p("cs.result_heading")}
          />
          <div class="grid grid-cols-2 gap-6">
            {
              stats.map((stat) => (
                <div class="flex flex-col items-start">
                  <div class="w-6 h-6 text-teal-600 mb-2">
                    <Icon name={stat.icon} />
                  </div>
                  <div class="text-3xl sm:text-4xl font-extrabold text-teal-600">
                    {stat.value}
                  </div>
                  <div class="text-base sm:text-lg text-slate-500 mt-1">
                    {stat.label}
                  </div>
                </div>
              ))
            }
          </div>
          <p class="mt-6 text-lg font-medium text-slate-600">
            {p("cs.stat_summary")}
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-8 text-center">
      <Link href={p("cs.cta_link")} size="lg" style="primary">
        {p("cs.cta")}
      </Link>
    </div>
  </Container>
</section>
