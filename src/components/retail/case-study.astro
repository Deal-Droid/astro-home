---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";

const page_ui: UILanguages = {
  en: {
    "cs.badge": "Real Results · Case Study",
    "cs.heading": 'Not just "trying AI"',
    "cs.subheading": "These are real results from month one",
    "cs.store_desc":
      "A leading drone retailer used DealDroid to handle Facebook Ads traffic across Messenger, LINE, and web chat — here's what happened in 30 days.",
    "cs.store_type": "🏪 Authorized Drone Dealer",
    "cs.store_detail":
      "Multi-channel retail store selling premium electronics. Running significant Facebook & Google Ads with high daily chat volume across Messenger and website.",
    "cs.result_heading":
      "In the first month with DealDroid, AI handled 90%+ of all customer chats",
    "cs.stat1_value": "2,930",
    "cs.stat1_label": "Customers handled by DealDroid AI",
    "cs.stat2_value": "80%",
    "cs.stat2_label": "Resolved by AI — no human needed",
    "cs.stat3_value": "10%",
    "cs.stat3_label": "Qualified & handed to team to close",
    "cs.stat4_value": "24/7",
    "cs.stat4_label": "Coverage when staff is offline",
    "cs.stat_summary": "Handled all ad traffic without hiring additional staff",
    "cs.cta": "See the Full Case Study in Your Free Inbox Audit",
    "cs.cta_link": "https://cal.com",
    "cs.channels": "Messenger · Website",
  },
  th: {
    "cs.badge": "Real Results · Case Study",
    "cs.heading": 'ไม่ใช่แค่ "ลองใช้ AI"',
    "cs.subheading": "นี่คือผลลัพธ์จริงใน 1 เดือน",
    "cs.store_desc":
      "ร้านค้าขาย Drone ชั้นนำในไทย ระดับเดียวกับร้านที่คุณใช้ DealDroid รับมือ traffic จาก Facebook Ads ในเดือน พ.ย 2025",
    "cs.store_type": "Authorized DJI Drones Dealer in Thailand",
    "cs.store_detail": "",
    "cs.result_heading":
      "เดือนแรกที่ใช้ DealDroid AI ตอบลูกค้าแทน Admin ให้มากกว่า 90%",
    "cs.stat1_value": "2,930",
    "cs.stat1_label": "ลูกค้าที่ DealDroid AI ตอบให้ทั้งหมด",
    "cs.stat2_value": "80%",
    "cs.stat2_label": "AI จบให้แบบไม่ต้องให้คนช่วย",
    "cs.stat3_value": "10%",
    "cs.stat3_label": "AI กรองแล้วส่งต่อให้คนช่วยปิด",
    "cs.stat4_value": "24/7",
    "cs.stat4_label": "ดูแลลูกค้าให้ในเมื่อ admin ไม่อยู่",
    "cs.stat_summary": "ช่วยรับทราฟฟิกจากแอดได้ โดยไม่ต้องเพิ่มแอดมิน",
    "cs.cta": "ขอดูรายละเอียด Full Case Study ใน ช่วงนัดคุยวิเคราะห์ Inbox",
    "cs.cta_link": "https://line.me/R/ti/p/@dealdroid",
    "cs.channels": "Messenger · LINE · Website",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);

const stats = [
  {
    value: p("cs.stat1_value"),
    label: p("cs.stat1_label"),
    color: "text-indigo-600",
  },
  {
    value: p("cs.stat2_value"),
    label: p("cs.stat2_label"),
    color: "text-green-600",
  },
  {
    value: p("cs.stat3_value"),
    label: p("cs.stat3_label"),
    color: "text-orange-500",
  },
  {
    value: p("cs.stat4_value"),
    label: p("cs.stat4_label"),
    color: "text-purple-600",
  },
];
---

<section id="proof" class="py-16 bg-white">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span
        class="inline-block bg-green-100 border border-green-200 text-green-700 text-xs font-semibold px-4 py-1.5 rounded-full mb-4">
        {p("cs.badge")}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        {p("cs.heading")}
      </h2>
      <p class="text-xl text-slate-600">{p("cs.subheading")}</p>
    </div>

    <!-- Store Info -->
    <div class="max-w-3xl mx-auto mb-10">
      <div class="bg-slate-50 rounded-2xl border border-slate-200 p-6 md:p-8">
        <div class="flex flex-col md:flex-row items-start gap-4 mb-4">
          <div>
            <p class="text-sm font-medium text-slate-500 mb-1">
              {p("cs.store_type")}
            </p>
            <p class="text-slate-600 text-sm">{p("cs.store_desc")}</p>
            {
              p("cs.store_detail") && (
                <p class="text-slate-500 text-sm mt-2">
                  {p("cs.store_detail")}
                </p>
              )
            }
          </div>
        </div>
        <div class="flex gap-2 flex-wrap">
          {
            p("cs.channels")
              .split(" · ")
              .map((ch) => (
                <span class="text-xs bg-white border border-slate-200 rounded-full px-3 py-1 text-slate-600">
                  {ch}
                </span>
              ))
          }
        </div>
      </div>
    </div>

    <!-- Result Heading -->
    <h3
      class="text-xl md:text-2xl font-bold text-center text-slate-900 mb-8 max-w-2xl mx-auto">
      {p("cs.result_heading")}
    </h3>

    <!-- 4 Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto mb-6">
      {
        stats.map((stat) => (
          <div class="bg-white rounded-xl border border-slate-200 p-5 text-center shadow-sm">
            <div class:list={["text-3xl font-bold", stat.color]}>
              {stat.value}
            </div>
            <div class="text-xs text-slate-500 mt-2">{stat.label}</div>
          </div>
        ))
      }
    </div>

    <!-- Summary -->
    <p class="text-center text-sm text-slate-500 mb-8">
      {p("cs.stat_summary")}
    </p>

    <!-- CTA -->
    <div class="text-center">
      <Link href={p("cs.cta_link")} size="lg" style="primary">
        {p("cs.cta")}
      </Link>
    </div>
  </Container>
</section>
