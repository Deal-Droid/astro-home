---
import Container from "@components/container.astro";
import { Image } from "astro:assets";
import ownerImg from "@assets/customer/dji13store-owner.png";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";

const page_ui: UILanguages = {
  en: {
    "test.quote":
      '"DealDroid AI handled nearly 3,000 customers in one month. 80% were resolved by AI alone — no human needed — even during our heaviest ad campaigns."',
    "test.name": "CEO, Authorized Electronics Dealer",
    "test.title": "Premium drone & electronics retail brand",
  },
  th: {
    "test.quote":
      '"DealDroid AI รับลูกค้าเกือบ 3,000 รายใน 1 เดือน.. 80% AI จบเอง ไม่ต้องให้น้อง Admin เข้ามาช่วย แม้ช่วงที่รัน ad campaign ที่ traffic หนักสุดๆ"',
    "test.name": "ณัฐชนน ชีวะวัฒนากร (นัท)",
    "test.title": "CEO, DJI 13 Store — Authorized DJI Drone Dealer in Thailand",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);
---

<section class="py-16 bg-white">
  <Container>
    <div class="max-w-3xl mx-auto text-center">
      <blockquote class="text-2xl md:text-3xl font-bold text-slate-900 mb-8">
        {p("test.quote")}
      </blockquote>

      <Image
        src={ownerImg}
        alt={p("test.name")}
        width={96}
        height={96}
        class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover mx-auto shadow-md border-3 border-slate-100 mb-4"
      />

      <div class="font-semibold text-slate-900">{p("test.name")}</div>
      <div class="text-sm text-slate-500 mt-1">{p("test.title")}</div>
    </div>
  </Container>
</section>
