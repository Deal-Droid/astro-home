---
interface Props {
  theme: "default" | "whatsapp";
  storeName: string;
  storeLogo: string;
}

const { theme, storeName, storeLogo } = Astro.props;
const isWhatsapp = theme === "whatsapp";
---

<div
  class:list={[
    "chat-messages flex-1 min-h-0 p-4 flex flex-col gap-3 overflow-y-auto no-scrollbar",
    isWhatsapp ? "bg-[#ECE5DD]" : "bg-slate-50",
  ]}>
  <div class="chat-spacer flex-grow"></div>
  <!-- Typing Indicator: inside scroll area, opacity-only show/hide so height never changes -->
  <div class="chat-typing" aria-hidden="true">
    {
      isWhatsapp ? (
        <div class="flex items-end gap-2">
          <div class="bg-[#DCF8C6] rounded-2xl rounded-bl-sm px-4 py-2.5">
            <div class="flex gap-1 items-center">
              <span class="typing-dot w-2 h-2 bg-slate-500 rounded-full" />
              <span class="typing-dot w-2 h-2 bg-slate-500 rounded-full" />
              <span class="typing-dot w-2 h-2 bg-slate-500 rounded-full" />
            </div>
          </div>
        </div>
      ) : (
        <div class="flex items-end gap-2">
          <div class="w-6 h-6 shrink-0 rounded-full overflow-hidden bg-indigo-50">
            <img src={storeLogo} alt={storeName} class="w-full h-full object-cover" />
          </div>
          <div class="bg-white border border-slate-200 rounded-2xl rounded-bl-md px-4 py-2.5 shadow-sm">
            <div class="flex gap-1 items-center">
              <span class="typing-dot w-2 h-2 bg-slate-400 rounded-full" />
              <span class="typing-dot w-2 h-2 bg-slate-400 rounded-full" />
              <span class="typing-dot w-2 h-2 bg-slate-400 rounded-full" />
            </div>
          </div>
        </div>
      )
    }
  </div>
</div>
