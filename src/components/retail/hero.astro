---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import ChatSimulation from "./chat-simulation.astro";
import { usePageTranslations, useTranslatedPath } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";
import messengerSvg from "@assets/channels/messenger.svg";
import lineSvg from "@assets/channels/line.svg";
import whatsappSvg from "@assets/channels/whatsapp.svg";
import instagramSvg from "@assets/channels/instagram.svg";
import websiteSvg from "@assets/channels/website.svg";
import happyPupDuck from "@assets/brands/happy-pup-duck.jpg";
import happyPupFish from "@assets/brands/happy-pup-fish.jpg";

const page_ui: UILanguages = {
  en: {
    "hero.badge": "AI Sales Agent for Serious E-Commerce Brands",
    "hero.h1": "Reply Faster. Lose Fewer Leads. Close Sales with AI.",
    "hero.subtitle":
      "DealDroid AI replaces your chat team 24/7 — instant replies, product recommendations, and closes deals while you sleep. No extra headcount needed.",
    "hero.cta_primary": "Get Free Inbox Audit",
    "hero.cta_secondary": "See Real Results",
    "hero.stat1_value": "80%",
    "hero.stat1_label": "Chats handled by AI — no human needed",
    "hero.stat2_value": "24/7",
    "hero.stat2_label": "Always selling, never sleeping",
    "hero.stat3_value": "118+",
    "hero.stat3_label": "Languages supported out of the box",
    "hero.stat4_value": "↗ Peak",
    "hero.stat4_label": "Handles campaign traffic surges",
    "hero.channels_label": "Connects with",
    "hero.store_name": "TechGear SG",
    "hero.chat_msg1": "Hi! How much is the Sony WH-1000XM5?",
    "hero.chat_reply1":
      "Hey there! 👋 The Sony WH-1000XM5 is S$449.\n\n🎧 Right now we have a bundle deal — get a free carrying case worth S$59!\n\n📦 Only 5 left in stock.",
    "hero.chat_msg2": "Deal! I'll take one.",
    "hero.cta_link": "https://cal.com",
  },
  th: {
    "hero.badge": "AI Sales Agent สำหรับ Brand ที่มียอดขายจริงจัง",
    "hero.h1": "ตอบแชทเร็วกว่า ลูกค้าไม่หาย ปิดการขายด้วย AI",
    "hero.subtitle":
      "ให้ DealDroid AI ตอบแชทแทน Admin ของคุณ ตอบทันทีลูกค้าไม่รอ 24 ชั่วโมงไม่เว้นวันหยุด ปิดการขายให้ รองรับแชทพุ่งเมื่อยิง ads โดยไม่ต้องจ้างคนเพิ่ม",
    "hero.cta_primary": "นัดคุยวิเคราะห์ Inbox ฟรี",
    "hero.cta_secondary": "ดูผลลัพธ์จริง",
    "hero.stat1_value": "80%",
    "hero.stat1_label": "จบ Chat โดย bot เอง ไม่ต้องให้คนช่วย",
    "hero.stat2_value": "24/7",
    "hero.stat2_label": "ขายแบบไม่มีวันหยุด",
    "hero.stat3_value": "118+",
    "hero.stat3_label": "ภาษา รองรับลูกค้าต่างชาติ",
    "hero.stat4_value": "↗ Peak",
    "hero.stat4_label": "รองรับแชทพุ่งช่วงแคมเปญ",
    "hero.channels_label": "เชื่อมต่อกับ",
    "hero.store_name": "Mochi",
    "hero.chat_msg1": "Happy Pup ทำจากเป็ด ราคาเท่าไหร่คะ?",
    "hero.chat_reply1": "อาหารสุนัข Happy Pup – Duck ราคา 140 บาท ครับ",
    "hero.chat_msg2": "เอา 2 ถุง",
    "hero.cta_link": "https://line.me/R/ti/p/@dealdroid",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);
const translatePath = useTranslatedPath(lang);

const channels = [
  { name: "Messenger", icon: messengerSvg.src },
  { name: "LINE", icon: lineSvg.src },
  { name: "WhatsApp", icon: whatsappSvg.src },
  { name: "Instagram", icon: instagramSvg.src },
  { name: "Website", icon: websiteSvg.src },
];

const stats = [
  { value: p("hero.stat1_value"), label: p("hero.stat1_label") },
  { value: p("hero.stat2_value"), label: p("hero.stat2_label") },
  { value: p("hero.stat3_value"), label: p("hero.stat3_label") },
  { value: p("hero.stat4_value"), label: p("hero.stat4_label") },
];

type Msg = { sender: "bot" | "customer"; text: string; image?: string };

const chatConversations: Msg[][] =
  lang === "th"
    ? [
        // Set A - สั่งซื้ออาหารสุนัข
        [
          { sender: "customer", text: "Happy Pup ทำจากเป็ด ราคาเท่าไหร่คะ" },
          {
            sender: "bot",
            text: "อาหารสุนัข Happy Pup – Duck ราคา 140 บาท ครับ",
          },
          {
            sender: "bot",
            text: "",
            image: happyPupDuck.src,
          },
          {
            sender: "bot",
            text: "สนใจรับไปเลยมั๊ยคะ 😊",
          },
          { sender: "customer", text: "เอา 2 ถุง" },
          {
            sender: "bot",
            text: "ยินดีเลยค่ะ 🎉\n\nใส่สินค้า Happy Pup Dog Food – Duck - 10kg จำนวน 2 ถุง ในตะกร้าแล้ว\nราคารวมอยู่ที่ 280 บาท\n\nคุณลูกค้าจะจ่ายเป็นโอนเงิน หรือเก็บเงินปลายทางดีคะ",
          },
          { sender: "customer", text: "เก็บเงินปลายทางค่ะ" },
          {
            sender: "bot",
            text: "ได้เลยค่ะ คุณลูกค้าแจ้งชื่อ-ที่อยู่เพื่อจัดส่งให้ถูกต้องได้เลยค่ะ 📦",
          },
        ],
        // Set B - ถามบริการอาบน้ำ (out of scope)
        [
          { sender: "customer", text: "อาบน้ำหมา ราคาเท่าไรคะ?" },
          {
            sender: "bot",
            text: "ขออภัยค่ะ ทางร้านไม่มีบริการอาบน้ำสุนัข\n\nแต่มีอาหารสุนัขคุณภาพดี เช่น Happy Pup Dog Food – Ocean Fish และ Happy Pup Dog Food – Duck ซึ่งเป็นอาหารที่ดีต่อสุขภาพสุนัข\n\nคุณลูกค้าสนใจรับไปลองดูมั๊ยคะ? 😊",
          },
          { sender: "customer", text: "ขอคิดดูก่อนนะคะ" },
          {
            sender: "bot",
            text: "ได้เลยค่ะ ถ้าคุณลูกค้าสนใจหรือมีคำถามเพิ่มเติมเกี่ยวกับอาหารสุนัข Happy Pup สามารถทักมาหาเราได้ตลอดเลยนะคะ",
          },
          { sender: "bot", text: "ยินดีให้คำแนะนำค่ะ 😊" },
        ],
        // Set C - อาหารสำหรับหมาแพ้ง่าย
        [
          {
            sender: "customer",
            text: "สนใจอาหารสำหรับน้องหมาแพ้ง่ายค่ะ",
          },
          {
            sender: "bot",
            text: "เรามีอาหารเม็ดสำหรับสุนัขแพ้ง่าย เช่น สูตรเนื้อปลาแซลมอนและปลาทูน่า สนใจลองดูมั๊ยคะ? 😊",
          },
          { sender: "customer", text: "มีอะไรบ้างคะ" },
          {
            sender: "bot",
            text: "เรามีอาหารสุนัขสำหรับแพ้ง่าย 2 สูตรหลัก ได้แก่\n\n• สูตรเนื้อปลา (Ocean Fish) – ไม่มีข้าวและกลูเตน มีโอเมก้า 3 & 6 ช่วยบำรุงขนและผิว\n• สูตรเนื้อเป็ด (Duck) – ง่ายต่อการย่อย ไม่มีสารก่อภูมิแพ้ และเพิ่มผักเสริมโภชนาการ\n\nสนใจตัวไหนดีคะ?",
          },
          { sender: "customer", text: "ปลาค่ะ" },
          {
            sender: "bot",
            text: "สูตรเนื้อปลา (Ocean Fish) นี้เหมาะสำหรับน้องหมาที่แพ้สัตว์ปีก มีโปรตีนจากปลาแซลมอนและปลาทูน่า ช่วยบำรุงขนให้นุ่มสวย และผิวหนังแข็งแรง ไม่มีข้าวหรือกลูเตน 🐾",
          },
          {
            sender: "bot",
            text: "",
            image: happyPupFish.src,
          },
          { sender: "customer", text: "โอเคค่ะ เอา 1 ถุง" },
          {
            sender: "bot",
            text: "เยี่ยมเลยค่ะ 🎉\n\nใส่สินค้า Happy Pup Dog Food – Ocean Fish - 10kg จำนวน 1 ถุง ในตะกร้าแล้ว\nราคารวมอยู่ที่ 150 บาท\n\nคุณลูกค้าจะจ่ายเป็นโอนเงิน หรือเก็บเงินปลายทางดีคะ",
          },
        ],
      ]
    : [
        // Set A - Authenticity concern
        [
          {
            sender: "customer",
            text: "Is this authentic? I'm worried about fakes",
          },
          {
            sender: "bot",
            text: "100% authentic! We're an authorized retailer.\n\n✅ 1-year warranty\n✅ Official receipt provided\n✅ Sourced directly from authorized distributors\n\nShop with confidence! 😊",
          },
        ],
        // Set B - Price inquiry + deal close
        [
          {
            sender: "customer",
            text: "Hi! How much is the Sony WH-1000XM5?",
          },
          {
            sender: "bot",
            text: "Hey there! 👋 The Sony WH-1000XM5 is S$449.\n\n🎧 Right now we have a bundle deal — get a free carrying case worth S$59!\n\n📦 Only 5 left in stock.",
          },
          {
            sender: "customer",
            text: "Deal! I'll take one.",
          },
        ],
        // Set C - Store visit
        [
          {
            sender: "customer",
            text: "Do you have stores I can visit?",
          },
          {
            sender: "bot",
            text: "Yes! We have 2 locations:\n\n📍 Orchard Central\nOpen 11am–9pm daily\n📞 +65 6123 4567\n\n📍 VivoCity\nOpen 10am–10pm daily\n📞 +65 6789 0123\n\nWelcome anytime! 😊",
          },
        ],
      ];
---

<section class="bg-white pt-8 pb-16 overflow-hidden">
  <Container>
    <div class="py-4 grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Left: Copy -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="mb-6">
          <span
            class="inline-block bg-indigo-100 border border-indigo-200 text-indigo-700 text-xs font-semibold px-4 py-1.5 rounded-full">
            {p("hero.badge")}
          </span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight text-slate-900">
          {p("hero.h1")}
        </h1>
        <p class="mt-6 text-lg text-slate-600 max-w-xl mx-auto lg:mx-0">
          {p("hero.subtitle")}
        </p>
        <div
          class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Link href={p("hero.cta_link")} size="lg" style="primary">
            {p("hero.cta_primary")}
          </Link>
          <Link
            href={`${translatePath("/retail")}#proof`}
            size="lg"
            style="outline">
            {p("hero.cta_secondary")}
          </Link>
        </div>

        <!-- Channel Icons -->
        <div
          class="mt-6 flex flex-wrap items-center gap-3 justify-center lg:justify-start">
          <span class="text-sm text-slate-400 font-medium"
            >{p("hero.channels_label")}</span
          >
          <div class="flex flex-wrap items-center gap-3">
            {
              channels.map((ch) => (
                <div class="flex items-center gap-1.5">
                  <img src={ch.icon} alt={ch.name} class="w-5 h-5 shrink-0" />
                  <span class="text-xs font-medium text-slate-400">
                    {ch.name}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Right: Chat Mockup (offset left for visual balance) -->
      <div class="flex justify-center lg:-ml-4">
        <ChatSimulation
          storeName={p("hero.store_name")}
          conversations={chatConversations}
          typingDelay={6000}
          pauseBetween={8000}
        />
      </div>
    </div>

    <!-- Stats Strip — prominent, no card borders, with divider above -->
    <div class="mt-14 pt-16 border-t border-slate-200">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {
          stats.map((stat) => (
            <div class="text-start">
              <div class="text-3xl md:text-4xl font-bold text-indigo-600">
                {stat.value}
              </div>
              <div class="text-base text-slate-500 mt-1.5">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
