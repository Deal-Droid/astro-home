---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import ChatSimulation from "./chat-simulation.astro";
import { usePageTranslations, useTranslatedPath } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";
import messengerSvg from "@assets/channels/messenger.svg";
import lineSvg from "@assets/channels/line.svg";
import whatsappSvg from "@assets/channels/whatsapp.svg";
import instagramSvg from "@assets/channels/instagram.svg";
import websiteSvg from "@assets/channels/website.svg";
import shopeeSvg from "@assets/channels/shopee.svg";

const page_ui: UILanguages = {
  en: {
    "hero.badge": "AI Sales Agent for Serious E-Commerce Brands",
    "hero.h1": "Reply Faster. Lose Fewer Leads. Close Sales with AI.",
    "hero.subtitle":
      "DealDroid AI replaces your chat team 24/7 — instant replies, product recommendations, and closes deals while you sleep. No extra headcount needed.",
    "hero.cta_primary": "Get Free Inbox Audit",
    "hero.cta_secondary": "See Real Results",
    "hero.stat1_value": "80%",
    "hero.stat1_label": "Chats handled by AI — no human needed",
    "hero.stat2_value": "24/7",
    "hero.stat2_label": "Always selling, never sleeping",
    "hero.stat3_value": "118+",
    "hero.stat3_label": "Languages supported out of the box",
    "hero.stat4_value": "↗ Peak",
    "hero.stat4_label": "Handles campaign traffic surges",
    "hero.channels_label": "Connects with",
    "hero.store_name": "TechGear SG",
    "hero.chat_msg1": "Hi! How much is the Sony WH-1000XM5?",
    "hero.chat_reply1":
      "Hey there! 👋 The Sony WH-1000XM5 is S$449.\n\n🎧 Right now we have a bundle deal — get a free carrying case worth S$59!\n\n📦 Only 5 left in stock.",
    "hero.chat_msg2": "Deal! I'll take one.",
    "hero.cta_link": "https://cal.com",
  },
  th: {
    "hero.badge": "AI Sales Agent สำหรับ Brand ที่มียอดขายจริงจัง",
    "hero.h1": "ตอบแชทเร็วกว่า ลูกค้าไม่หาย ปิดการขายด้วย AI",
    "hero.subtitle":
      "ให้ DealDroid AI ตอบแชทแทน Admin ของคุณ ตอบทันทีลูกค้าไม่รอ 24 ชั่วโมงไม่เว้นวันหยุด ปิดการขายให้ รองรับแชทพุ่งเมื่อยิง ads โดยไม่ต้องจ้างคนเพิ่ม",
    "hero.cta_primary": "นัดคุยวิเคราะห์ Inbox ฟรี",
    "hero.cta_secondary": "ดูผลลัพธ์จริง",
    "hero.stat1_value": "80%",
    "hero.stat1_label": "จบ Chat โดย bot เอง ไม่ต้องให้คนช่วย",
    "hero.stat2_value": "24/7",
    "hero.stat2_label": "ขายแบบไม่มีวันหยุด",
    "hero.stat3_value": "118+",
    "hero.stat3_label": "ภาษา รองรับลูกค้าต่างชาติ",
    "hero.stat4_value": "↗ Peak",
    "hero.stat4_label": "รองรับแชทพุ่งช่วงแคมเปญ",
    "hero.channels_label": "เชื่อมต่อกับ",
    "hero.store_name": "DJI 13 Store",
    "hero.chat_msg1": "DJI Mini 4 Pro ราคาเท่าไหร่คะ?",
    "hero.chat_reply1":
      "DJI Mini 4 Pro ราคา 27,990 บาทครับ\nตอนนี้ซื้อคู่กับ DJI RC 2 ลดเพิ่มอีก 2,000 บาท!\n\n📦 เหลือ 3 ตัวสุดท้ายครับ",
    "hero.chat_msg2": "ขอดูรูปหน่อยได้มั้ยค่ะ",
    "hero.cta_link": "https://line.me/R/ti/p/@dealdroid",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);
const translatePath = useTranslatedPath(lang);

const channels =
  lang === "th"
    ? [
        { name: "Messenger", icon: messengerSvg.src },
        { name: "LINE", icon: lineSvg.src },
        { name: "WhatsApp", icon: whatsappSvg.src },
        { name: "Instagram", icon: instagramSvg.src },
        { name: "Website", icon: websiteSvg.src },
      ]
    : [
        { name: "Messenger", icon: messengerSvg.src },
        { name: "WhatsApp", icon: whatsappSvg.src },
        { name: "Instagram", icon: instagramSvg.src },
        { name: "Website", icon: websiteSvg.src },
        { name: "Shopee", icon: shopeeSvg.src },
      ];

const stats = [
  { value: p("hero.stat1_value"), label: p("hero.stat1_label") },
  { value: p("hero.stat2_value"), label: p("hero.stat2_label") },
  { value: p("hero.stat3_value"), label: p("hero.stat3_label") },
  { value: p("hero.stat4_value"), label: p("hero.stat4_label") },
];

const chatMessages = [
  { sender: "customer" as const, text: p("hero.chat_msg1") },
  { sender: "bot" as const, text: p("hero.chat_reply1") },
  { sender: "customer" as const, text: p("hero.chat_msg2") },
];
---

<section class="bg-white pt-8 pb-16 overflow-hidden">
  <Container>
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Left: Copy -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="mb-6">
          <span
            class="inline-block bg-indigo-100 border border-indigo-200 text-indigo-700 text-xs font-semibold px-4 py-1.5 rounded-full">
            {p("hero.badge")}
          </span>
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-[3.25rem] font-bold leading-tight text-slate-900">
          {p("hero.h1")}
        </h1>
        <p class="mt-6 text-lg text-slate-600 max-w-xl mx-auto lg:mx-0">
          {p("hero.subtitle")}
        </p>
        <div
          class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Link href={p("hero.cta_link")} size="lg" style="primary">
            {p("hero.cta_primary")}
          </Link>
          <Link
            href={`${translatePath("/retail")}#proof`}
            size="lg"
            style="outline">
            {p("hero.cta_secondary")}
          </Link>
        </div>

        <!-- Channel Icons -->
        <div
          class="mt-6 flex flex-wrap items-center gap-3 justify-center lg:justify-start">
          <span
            class="text-sm text-slate-400 font-medium"
            >{p("hero.channels_label")}</span
          >
          <div class="flex flex-wrap items-center gap-3">
            {
              channels.map((ch) => (
                <div class="flex items-center gap-1.5">
                  <img src={ch.icon} alt={ch.name} class="w-5 h-5 shrink-0" />
                  <span class="text-xs font-medium text-slate-400">{ch.name}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Right: Chat Mockup (offset left for visual balance) -->
      <div class="flex justify-center lg:-ml-4">
        <ChatSimulation
          storeName={p("hero.store_name")}
          messages={chatMessages}
        />
      </div>
    </div>

    <!-- Stats Strip — prominent, no card borders, with divider above -->
    <div class="mt-14 pt-8 border-t border-slate-200">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {
          stats.map((stat) => (
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-extrabold text-indigo-600">
                {stat.value}
              </div>
              <div class="text-sm text-slate-500 mt-1.5">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
