---
import Container from "@components/container.astro";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";

const page_ui: UILanguages = {
  en: {
    "bb.heading": "Built by ShakeSphere",
    "bb.subheading":
      "A Southeast Asian tech consultancy delivering digital products and AI systems for 20+ years",
    "bb.powered": "POWERED BY",
    "bb.desc":
      "Tech consulting and product development with 2 decades of experience. We build digital platforms and AI systems for enterprises across Southeast Asia and startups worldwide.",
    "bb.stat1_num": "20+",
    "bb.stat1_label": "Years of experience",
    "bb.stat2_num": "100+",
    "bb.stat2_label": "Projects delivered",
    "bb.stat3_label": "AI Core expertise",
    "bb.stat4_label": "SEA Regional team · Bangkok",
    "bb.trusted": "Trusted by",
  },
  th: {
    "bb.heading": "สร้างโดยทีม ShakeSphere",
    "bb.subheading":
      "บริษัท Tech Consulting ไทย ที่ทำ Digital Project ให้กับองค์กรชั้นนำมากกว่า 20 ปี",
    "bb.powered": "POWERED BY",
    "bb.desc":
      "Tech Consulting และ Product Development ที่มีประสบการณ์กว่า 2 ทศวรรษ สร้าง Digital Platforms และ AI systems ให้กับ Enterprises ในไทย และ Startups ทั่วโลก",
    "bb.stat1_num": "20+",
    "bb.stat1_label": "ปีประสบการณ์",
    "bb.stat2_num": "100+",
    "bb.stat2_label": "Projects delivered",
    "bb.stat3_label": "AI Core expertise",
    "bb.stat4_label": "TH Local team · Bangkok",
    "bb.trusted": "Trusted by",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);

const stats = [
  { num: p("bb.stat1_num"), label: p("bb.stat1_label") },
  { num: p("bb.stat2_num"), label: p("bb.stat2_label") },
];

// Enterprise logos from source
const logos = [
  {
    name: "Minor International",
    src: "https://go.dealdroid.ai/assets/minor-YWnKWjYa.svg",
  },
  {
    name: "Central Group",
    src: "https://go.dealdroid.ai/assets/central-group-D1IDVwlO.svg",
  },
  { name: "SCG", src: "https://go.dealdroid.ai/assets/scg-DtP9Ndin.png" },
  { name: "SCB", src: "https://go.dealdroid.ai/assets/scb-B6Mvjlu-.png" },
  { name: "Citi", src: "https://go.dealdroid.ai/assets/citi-CvYErjcL.png" },
  {
    name: "Auntie Anne's",
    src: "https://go.dealdroid.ai/assets/auntie-annes-DiBkzGdw.png",
  },
  {
    name: "BEC Tero",
    src: "https://go.dealdroid.ai/assets/bec-tero-mU1PE7YO.svg",
  },
  {
    name: "Thaiticket Major",
    src: "https://go.dealdroid.ai/assets/thaiticket-major-DdT3UWM1.png",
  },
  {
    name: "Major Cineplex",
    src: "https://go.dealdroid.ai/assets/major-cineplex-CmFri5HV.svg",
  },
  { name: "WHO", src: "https://go.dealdroid.ai/assets/who-CC5gakrr.png" },
];
---

<section class="py-16 bg-slate-50">
  <Container>
    <!-- Heading -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        {p("bb.heading")}
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        {p("bb.subheading")}
      </p>
    </div>

    <!-- Description -->
    <div class="max-w-3xl mx-auto text-center mb-8">
      <p
        class="text-xs uppercase tracking-widest text-indigo-600 font-semibold mb-2">
        {p("bb.powered")}
      </p>
      <p class="text-slate-600 text-sm">{p("bb.desc")}</p>
    </div>

    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-8 mb-12">
      {
        stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl font-bold text-indigo-600">{stat.num}</div>
            <div class="text-xs text-slate-500 mt-1">{stat.label}</div>
          </div>
        ))
      }
      <div class="text-center">
        <div class="text-xs text-slate-500">{p("bb.stat3_label")}</div>
      </div>
      <div class="text-center">
        <div class="text-xs text-slate-500">{p("bb.stat4_label")}</div>
      </div>
    </div>

    <!-- Trusted by -->
    <div class="mb-6">
      <p
        class="text-center text-xs font-semibold text-slate-400 tracking-widest uppercase mb-4">
        {p("bb.trusted")}
      </p>
      <div class="flex flex-wrap justify-center gap-6 items-center">
        {
          logos.map((logo) => (
            <img
              src={logo.src}
              alt={logo.name}
              class="h-6 w-auto object-contain grayscale opacity-70 hover:opacity-100 hover:grayscale-0 transition"
              loading="lazy"
            />
          ))
        }
      </div>
    </div>
  </Container>
</section>
