---
import Container from "@components/container.astro";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";
import minorSvg from "@assets/brands/minor.svg";
import centralGroupSvg from "@assets/brands/central-group.svg";
import scgImg from "@assets/brands/scg.png";
import scbImg from "@assets/brands/scb.png";
import citiImg from "@assets/brands/citi.png";
import auntieAnnesImg from "@assets/brands/auntie-annes.png";
import becTeroSvg from "@assets/brands/bec-tero.svg";
import thaiticketMajorImg from "@assets/brands/thaiticket-major.png";
import majorCineplexSvg from "@assets/brands/major-cineplex.svg";
import whoImg from "@assets/brands/who.png";
import lifepalSvg from "@assets/brands/lifepal.svg";
import shakesphereWhiteImg from "@assets/brands/shakesphere-white.png";

const page_ui: UILanguages = {
  en: {
    "bb.badge": "Developed by AI Experts",
    "bb.heading": "Built by ShakeSphere",
    "bb.subheading":
      "A Southeast Asian tech consultancy delivering digital products and AI systems for 20+ years",
    "bb.powered": "POWERED BY",
    "bb.desc":
      "Tech consulting and product development with 2 decades of experience. We build digital platforms and AI systems for enterprises across Southeast Asia and startups worldwide.",
    "bb.stat1_num": "20+",
    "bb.stat1_label": "Years of experience",
    "bb.stat2_num": "100+",
    "bb.stat2_label": "Projects delivered",
    "bb.stat3_num": "AI",
    "bb.stat3_label": "Core expertise",
    "bb.stat4_num": "SEA",
    "bb.stat4_label": "Regional team · Bangkok",
    "bb.trusted": "Trusted by",
    "bb.footer":
      "DealDroid AI is developed and maintained by ShakeSphere\nA team of Thai AI Engineers who truly understand SME businesses and Chat Commerce in Thailand",
  },
  th: {
    "bb.badge": "Developed by AI Experts",
    "bb.heading": "สร้างโดยทีม ShakeSphere",
    "bb.subheading":
      "บริษัท Tech Consulting ไทย ที่ทำ Digital Project ให้กับองค์กรชั้นนำมากกว่า 20 ปี",
    "bb.powered": "POWERED BY",
    "bb.desc":
      "Tech Consulting และ Product Development ที่มีประสบการณ์กว่า 2 ทศวรรษ สร้าง Digital Platforms และ AI systems ให้กับ Enterprises ในไทย และ Startups ทั่วโลก",
    "bb.stat1_num": "20+",
    "bb.stat1_label": "ปีประสบการณ์",
    "bb.stat2_num": "100+",
    "bb.stat2_label": "Projects delivered",
    "bb.stat3_num": "AI",
    "bb.stat3_label": "Core expertise",
    "bb.stat4_num": "TH",
    "bb.stat4_label": "Local team · Bangkok",
    "bb.trusted": "Trusted by",
    "bb.footer":
      "DealDroid AI ถูกพัฒนาขึ้นและดูแลโดยทีม ShakeSphere\nทีม AI Engineers ไทย ที่เข้าใจธุรกิจ SME และ Chat Commerce ของไทยอย่างแท้จริง",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);

const stats = [
  { num: p("bb.stat1_num"), label: p("bb.stat1_label") },
  { num: p("bb.stat2_num"), label: p("bb.stat2_label") },
  { num: p("bb.stat3_num"), label: p("bb.stat3_label") },
  { num: p("bb.stat4_num"), label: p("bb.stat4_label") },
];

const logos = [
  { name: "Minor International", src: minorSvg.src },
  { name: "Central Group", src: centralGroupSvg.src },
  { name: "SCG", src: scgImg.src },
  { name: "SCB", src: scbImg.src },
  { name: "Citi", src: citiImg.src },
  { name: "Auntie Anne's", src: auntieAnnesImg.src },
  { name: "BEC Tero", src: becTeroSvg.src },
  { name: "Thaiticket Major", src: thaiticketMajorImg.src },
  { name: "Major Cineplex", src: majorCineplexSvg.src },
  { name: "WHO", src: whoImg.src },
  { name: "Lifepal", src: lifepalSvg.src },
];
---

<section class="bg-slate-50 py-16 sm:py-24">
  <Container>
    <!-- Badge & Heading -->
    <div class="text-center mb-10">
      <span
        class="inline-block bg-indigo-600/10 text-indigo-600 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">
        {p("bb.badge")}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        {p("bb.heading")}
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        {p("bb.subheading")}
      </p>
    </div>

    <!-- Two-column grid -->
    <div class="grid lg:grid-cols-2 gap-6">
      <!-- Left: ShakeSphere card -->
      <div class="bg-indigo-600 rounded-2xl p-8 text-white">
        <p class="text-sm uppercase tracking-widest opacity-70 mb-2">
          {p("bb.powered")}
        </p>
        <img
          src={shakesphereWhiteImg.src}
          alt="ShakeSphere"
          class="h-8 mb-4"
          loading="lazy"
        />
        <p class="text-white/80 text-lg leading-relaxed mb-6">
          {p("bb.desc")}
        </p>
        <div class="grid grid-cols-2 gap-3">
          {
            stats.map((stat) => (
              <div class="bg-white/10 rounded-xl p-3 text-center">
                <div class="text-2xl font-bold">{stat.num}</div>
                <div class="text-sm opacity-70">{stat.label}</div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right: Trusted by logos -->
      <div class="bg-white border border-slate-200 rounded-2xl p-8">
        <p class="text-base font-semibold text-slate-400 mb-4">
          {p("bb.trusted")}
        </p>
        <div class="grid grid-cols-4 gap-x-6 gap-y-5">
          {
            logos.map((logo) => (
              <div class="flex items-center justify-center h-10">
                <img
                  src={logo.src}
                  alt={logo.name}
                  class="max-h-7 max-w-[90px] w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                  loading="lazy"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Footer text -->
    <p class="mt-8 text-lg text-slate-600/75 text-center max-w-2xl mx-auto whitespace-pre-line">
      {p("bb.footer")}
    </p>
  </Container>
</section>
