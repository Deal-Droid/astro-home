---
import Container from "@components/container.astro";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";
import messengerSvg from "@assets/channels/messenger.svg";
import lineSvg from "@assets/channels/line.svg";
import whatsappSvg from "@assets/channels/whatsapp.svg";
import instagramSvg from "@assets/channels/instagram.svg";
import websiteSvg from "@assets/channels/website.svg";

const page_ui: UILanguages = {
  en: {
    "sol.channels_label": "Connects with",
  },
  th: {
    "sol.channels_label": "รองรับการเชื่อมต่อกับ",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);

const channels = [
  { name: "Messenger", icon: messengerSvg.src },
  { name: "LINE", icon: lineSvg.src },
  { name: "WhatsApp", icon: whatsappSvg.src },
  { name: "Instagram", icon: instagramSvg.src },
  { name: "Website", icon: websiteSvg.src },
];
---

<section class="py-16 bg-white">
  <Container>
    <div class="text-center">
      <p class="text-sm font-medium text-slate-500 mb-6">{p("sol.channels_label")}</p>
      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-8">
        {
          channels.map((ch) => (
            <div class="flex items-center gap-2">
              <img src={ch.icon} alt={ch.name} class="w-8 h-8 md:w-10 md:h-10" />
              <span class="text-sm md:text-base font-semibold text-slate-700">
                {ch.name}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
