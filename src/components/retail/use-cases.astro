---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import ChatSimulation from "./chat-simulation.astro";
import { usePageTranslations, useTranslatedPath } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";
import { config } from "../../config";

const page_ui: UILanguages = {
  en: {
    "uc.badge": "Conversation Use Cases",
    "uc.heading": "From first hello to closed deal",
    "uc.subheading": "Real scenarios DealDroid AI handles every day",
    "uc.mid_cta_heading": "Want to see examples for your business?",
    "uc.mid_cta_desc":
      "Book a free 30-minute inbox analysis and we'll demo your exact use case",
    "uc.mid_cta_button": "Book Free Inbox Analysis",
    "uc.mid_cta_link": config.retail.register.en,
    "uc.store_name": "DJI 13 Store",
  },
  th: {
    "uc.badge": "Conversation Use Cases",
    "uc.heading": "จากทักครั้งแรก จนปิดการขาย",
    "uc.subheading": "สถานการณ์จริงที่ DealDroid AI พร้อมรับมือ",
    "uc.mid_cta_heading": "อยากดูตัวอย่างที่ตรงกับธุรกิจคุณ?",
    "uc.mid_cta_desc":
      "นัดคุยวิเคราะห์ Inbox ฟรี 30 นาที แล้วเราจะ Demo ให้ตรงเคสของคุณเลย",
    "uc.mid_cta_button": "นัดคุยวิเคราะห์ Inbox ฟรี",
    "uc.mid_cta_link": config.retail.register.th,
    "uc.store_name": "DJI 13 Store",
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);
const translatePath = useTranslatedPath(lang);

type Msg = { sender: "bot" | "customer"; text: string };

interface TabData {
  key: string;
  title: string;
  desc: string;
  checkText: string;
  conversation: Msg[];
}

const storeName = p("uc.store_name");

const tabs: TabData[] =
  lang === "th"
    ? [
        {
          key: "tab1",
          title: "ทักครั้งแรก",
          desc: "ต้อนรับด้วย Brand Voice + ข้อมูลร้าน",
          checkText: "ตอบทันที ไม่พลาดทุก Lead",
          conversation: [
            {
              sender: "customer",
              text: "สวัสดีค่ะ สนใจสินค้า อยากสอบถามหน่อย",
            },
            {
              sender: "bot",
              text: "สวัสดีครับ! ยินดีต้อนรับสู่ DJI 13 Store 🎉\n\nเราเป็นตัวแทนจำหน่าย DJI อย่างเป็นทางการ ของแท้ 100% พร้อมรับประกันศูนย์และส่งฟรีทั่วไทยครับ\n\nวันนี้สนใจสินค้าประเภทไหนเป็นพิเศษครับ?\n\n🚁 โดรน\n📷 กล้อง Action Camera\n🎒 อุปกรณ์เสริม",
            },
          ],
        },
        {
          key: "tab2",
          title: "แนะนำสินค้า",
          desc: "จับความต้องการ + แนะนำตัวเลือกที่ใช่",
          checkText: "ลูกค้าตัดสินใจเร็วขึ้น และออเดอร์ใหญ่ขึ้น",
          conversation: [
            {
              sender: "customer",
              text: "หูฟังไร้สาย งบประมาณ 3,000 บาท มีอะไรแนะนำมั้ยคะ",
            },
            {
              sender: "bot",
              text: "งบ 3,000 บาท แนะนำ 2 รุ่นนี้เลยครับ:\n\n🎧 Sony WF-C700N — 2,990 บาท\n✅ Noise Cancelling ดี\n✅ กันน้ำ IPX4\n✅ แบต 15 ชั่วโมง\n\n🎧 JBL Tune 230NC — 2,490 บาท\n✅ เบสหนัก\n✅ Active Noise Cancelling\n✅ แบต 10 ชั่วโมง\n\nชอบรุ่นไหนเป็นพิเศษครับ? 😊",
            },
          ],
        },
        {
          key: "tab3",
          title: "โน้มน้าวไปในทางปิดการขาย",
          desc: "แก้ข้อกังวล ชี้ความคุ้มค่า เปลี่ยนลังเลเป็นพร้อมซื้อ",
          checkText: "ลดอัตราทิ้งตะกร้า จากข้อกังวล",
          conversation: [
            {
              sender: "customer",
              text: "ราคาแพงกว่าร้านอื่นนะคะ ทำไมถึงควรซื้อกับร้านนี้",
            },
            {
              sender: "bot",
              text: "เข้าใจค่ะ! ราคาอาจสูงกว่านิดหน่อย แต่คุณได้มากกว่าค่ะ:\n\n✅ รับประกันศูนย์ 1 ปีเต็ม\n✅ อุปกรณ์เสริมฟรี กระเป๋าหูฟัง + สติกเกอร์\n✅ ส่งฟรีทั่วไทย 1-2 วันถึง\n✅ มีเซอร์วิสหลังขายตลอดอายุการใช้งาน\n\nร้านอื่นอาจถูกกว่า 200-300 บาท แต่ไม่มีบริการพวกนี้ค่ะ\n\nสนใจสั่งวันนี้มั้ยคะ? 🎁",
            },
          ],
        },
        {
          key: "tab4",
          title: "ปิดการขาย",
          desc: "สรุปออเดอร์ ถามข้อมูลจัดส่ง คำนวณค่าจัดส่ง และแจ้งวิธีชำระเงิน",
          checkText: "ปิดการขายอัตโนมัติ ลดงาน manual",
          conversation: [
            {
              sender: "customer",
              text: "เอา Sony WF-C700N ค่ะ",
            },
            {
              sender: "bot",
              text: "ดีมากครับ! สรุปออเดอร์ให้ครับ:\n\n🎧 Sony WF-C700N — 2,990 บาท\n📦 ส่งฟรี\n🎁 กระเป๋าหูฟังฟรี\n\n💰 รวม 2,990 บาท\n\nขอชื่อ-ที่อยู่จัดส่งหน่อยครับ 📦",
            },
            {
              sender: "customer",
              text: "ส่งที่ 123 ถ.สุขุมวิท แขวงคลองเตย เขตคลองเตย กรุงเทพฯ 10110",
            },
            {
              sender: "bot",
              text: "บันทึกแล้วครับ! 📝\n\nชำระเงินได้เลยที่:\n💳 PromptPay: 08X-XXX-XXXX\nหรือ\n🏦 โอนเข้าบัญชี กสิกรไทย\nชื่อบัญชี: DJI 13 Store\n\nส่งหลักฐานการโอนมาได้เลยครับ จะจัดส่งให้วันนี้เลย 🚀",
            },
          ],
        },
        {
          key: "tab5",
          title: "ตอบคำถามทั่วไป",
          desc: "ตอบคำถามซ้ำๆ ที่ลูกค้าถามบ่อย",
          checkText: "ประหยัดเวลาพนักงาน ตอบได้ 24/7",
          conversation: [
            {
              sender: "customer",
              text: "จัดส่งกี่วันคะ มีเก็บเงินปลายทางมั้ย",
            },
            {
              sender: "bot",
              text: "จัดส่ง 1-2 วันทำการค่ะ!\n\n🚚 ส่งฟรีทั่วไทย (สั่ง 1,000+ บาท)\n📦 แพ็คอย่างดี กันกระแทก\n\n✅ มีเก็บเงินปลายทางค่ะ (COD)\nกรุงเทพฯ และปริมณฑล ส่งวันรุ่งขึ้น\nต่างจังหวัด 1-2 วันทำการ\n\nต้องการสั่งเลยมั้ยคะ? 😊",
            },
          ],
        },
        {
          key: "tab6",
          title: "เคสนอกขอบเขต",
          desc: "รู้ขีดจำกัดตัวเอง ส่งต่อให้ Supervisor",
          checkText: "ไม่ทิ้งลูกค้า ส่งต่ออย่างมีบริบท",
          conversation: [
            {
              sender: "customer",
              text: "รับผ่อน 0% มั้ยคะ ผ่อนกี่เดือน",
            },
            {
              sender: "bot",
              text: "ตอนนี้ทางร้านยังไม่รับผ่อน 0% โดยตรงนะคะ\n\nแต่ทางเรามีเจ้าหน้าที่ที่ช่วยเรื่องนี้ได้ค่ะ!\n\n👥 ให้พนักงานติดต่อกลับไปได้มั้ยคะ?\nขอเบอร์โทรไว้ เดี๋ยวทีมส่งข้อมูลผ่อน 0% ให้ภายในวันนี้เลยค่ะ 😊",
            },
          ],
        },
      ]
    : [
        {
          key: "tab1",
          title: "First Contact",
          desc: "Welcome with brand voice + store info",
          checkText: "Instant reply, never miss a lead",
          conversation: [
            {
              sender: "customer",
              text: "Hi! I'm interested in your products, have some questions",
            },
            {
              sender: "bot",
              text: "Hello! Welcome to DJI 13 Store 🎉\n\nWe're an authorized DJI dealer — 100% genuine products with official warranty and free shipping nationwide.\n\nWhat are you looking for today?\n\n🚁 Drones\n📷 Action Cameras\n🎒 Accessories",
            },
          ],
        },
        {
          key: "tab2",
          title: "Product Recommendation",
          desc: "Understands needs + suggests the right fit",
          checkText: "Customers decide faster and order more",
          conversation: [
            {
              sender: "customer",
              text: "Looking for wireless earbuds around 3,000 baht, any recommendations?",
            },
            {
              sender: "bot",
              text: "At 3,000 baht, I'd recommend these 2:\n\n🎧 Sony WF-C700N — 2,990 baht\n✅ Great noise cancelling\n✅ IPX4 water resistant\n✅ 15hr battery life\n\n🎧 JBL Tune 230NC — 2,490 baht\n✅ Punchy bass\n✅ Active Noise Cancelling\n✅ 10hr battery life\n\nWhich one catches your eye? 😊",
            },
          ],
        },
        {
          key: "tab3",
          title: "Objection Handling",
          desc: "Addresses concerns, builds trust, moves toward close",
          checkText: "Reduce drop-offs from buyer hesitations",
          conversation: [
            {
              sender: "customer",
              text: "That's more expensive than other stores. Why should I buy here?",
            },
            {
              sender: "bot",
              text: "I understand! The price might be slightly higher, but you get much more:\n\n✅ Full 1-year official warranty\n✅ Free accessories (headphone case + sticker)\n✅ Free shipping nationwide, 1-2 day delivery\n✅ Lifetime after-sales support\n\nOther stores may be 200-300 baht cheaper, but without these services.\n\nWant to place an order today? 🎁",
            },
          ],
        },
        {
          key: "tab4",
          title: "Closing the Sale",
          desc: "Summarizes order, collects delivery info, sends payment",
          checkText: "Auto-close sales, less manual work",
          conversation: [
            {
              sender: "customer",
              text: "I'll take the Sony WF-C700N",
            },
            {
              sender: "bot",
              text: "Great choice! Here's your order summary:\n\n🎧 Sony WF-C700N — 2,990 baht\n📦 Free shipping\n🎁 Free headphone case\n\n💰 Total: 2,990 baht\n\nPlease share your name and delivery address 📦",
            },
            {
              sender: "customer",
              text: "123 Sukhumvit Road, Khlong Toei, Bangkok 10110",
            },
            {
              sender: "bot",
              text: "Got it! 📝\n\nPayment options:\n💳 PromptPay: 08X-XXX-XXXX\nor\n🏦 Bank Transfer: Kasikornbank\nAccount: DJI 13 Store\n\nSend us the payment slip and we'll ship it out today! 🚀",
            },
          ],
        },
        {
          key: "tab5",
          title: "FAQ Auto-Reply",
          desc: "Handles repetitive questions instantly",
          checkText: "Save staff time, respond 24/7",
          conversation: [
            {
              sender: "customer",
              text: "How long does shipping take? Do you offer COD?",
            },
            {
              sender: "bot",
              text: "Shipping takes 1-2 business days!\n\n🚚 Free shipping nationwide (orders 1,000+ baht)\n📦 Well-packed with bubble wrap\n\n✅ COD available!\nBangkok & nearby: next day\nOther provinces: 1-2 business days\n\nReady to order? 😊",
            },
          ],
        },
        {
          key: "tab6",
          title: "Out-of-Scope Handling",
          desc: "Knows its limits, hands off with full context",
          checkText: "Never leave customers hanging",
          conversation: [
            {
              sender: "customer",
              text: "Do you offer 0% installment plans?",
            },
            {
              sender: "bot",
              text: "We don't offer direct installment plans at the moment.\n\nBut our team can help you with that!\n\n👥 Would you like a staff member to reach out?\nShare your number and we'll send you installment options within the day 😊",
            },
          ],
        },
      ];
---

<section class="py-16 bg-slate-50">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span
        class="inline-block bg-indigo-100 border border-indigo-200 text-indigo-700 text-xs font-semibold px-4 py-1.5 rounded-full mb-4">
        {p("uc.badge")}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        {p("uc.heading")}
      </h2>
      <p class="text-lg text-slate-600">{p("uc.subheading")}</p>
    </div>

    <!-- Tabbed Use Cases -->
    <div class="max-w-6xl mx-auto" x-data="{
      activeTab: 'tab1',
      autoPlay: true,
      tabKeys: ['tab1','tab2','tab3','tab4','tab5','tab6'],
      nextTab() {
        const i = this.tabKeys.indexOf(this.activeTab);
        this.activeTab = this.tabKeys[(i + 1) % this.tabKeys.length];
      },
      handleComplete(tabKey) {
        if (this.autoPlay && this.activeTab === tabKey) {
          setTimeout(() => this.nextTab(), 2000);
        }
      }
    }" x-effect="
      $nextTick(() => {
        const el = $el.querySelector(`[data-tab-key='${activeTab}'] .chat-simulation`);
        if (el) el.dispatchEvent(new CustomEvent('chat-reset'));
      });
    ">
      <div class="grid lg:grid-cols-12 gap-6 lg:gap-10 items-start">
        <!-- Left: Tabs -->
        <div class="lg:col-span-5 lg:col-start-2">
          <div class="grid grid-cols-1 gap-1">
            {
              tabs.map((tab, i) => (
                <button
                  x-on:click={`autoPlay = false; activeTab = '${tab.key}'`}
                  x-bind:class={`activeTab === '${tab.key}' ? 'bg-indigo-600 text-white shadow-md' : 'bg-white text-slate-700 hover:bg-slate-50 border border-slate-200'`}
                  class="w-full text-left p-3 md:p-4 rounded-xl transition-all flex items-start gap-3">
                  <span
                    x-bind:class={`activeTab === '${tab.key}' ? 'bg-white/20 text-white' : 'bg-indigo-100 text-indigo-600'`}
                    class="w-7 h-7 md:w-8 md:h-8 rounded-full flex items-center justify-center text-xs md:text-sm font-bold shrink-0 transition-colors">
                    {i + 1}
                  </span>
                  <div class="min-w-0">
                    <div class="font-semibold text-sm md:text-base leading-tight">
                      {tab.title}
                    </div>
                    <div
                      x-bind:class={`activeTab === '${tab.key}' ? 'text-white/80' : 'text-slate-500'`}
                      class="hidden md:block text-xs md:text-sm mt-1 transition-colors">
                      {tab.desc}
                    </div>
                    <div
                      x-show={`activeTab === '${tab.key}'`}
                      x-cloak
                      class="mt-2 text-xs md:text-sm font-medium flex items-center gap-1.5 text-white/90">
                      <span>✅</span>
                      <span>{tab.checkText}</span>
                    </div>
                  </div>
                </button>
              ))
            }
          </div>
        </div>

        <!-- Right: Chat Simulations -->
        <div class="lg:col-span-6 flex justify-center lg:sticky lg:top-24">
          {
            tabs.map((tab) => (
              <div
                x-show={`activeTab === '${tab.key}'`}
                x-cloak
                data-tab-key={tab.key}
                x-on:chat-complete={`handleComplete('${tab.key}')`}
                class="w-full max-w-md">
                <ChatSimulation
                  storeName={storeName}
                  conversations={[tab.conversation]}
                  typingDelay={1200}
                  pauseBetween={8000}
                  loop={false}
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Mid CTA -->
    <div class="mt-16 text-center">
      <p class="text-xl font-bold text-slate-900 mb-2">
        {p("uc.mid_cta_heading")}
      </p>
      <p class="text-slate-500 mb-6">
        {p("uc.mid_cta_desc")}
      </p>
      <Link
        href={p("uc.mid_cta_link")}
        size="lg"
        style="primary"
        class="inline-block">
        {p("uc.mid_cta_button")}
      </Link>
    </div>
  </Container>
</section>

<!-- Alpine.js for tabs (loaded once) -->
<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
  defer></script>
<style>
  [x-cloak] {
    display: none !important;
  }
</style>
