---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";
import { config } from "../../config";

const page_ui: UILanguages = {
  en: {
    "steps.heading": "Go live in 48 hours — AI starts selling immediately",
    "steps.step1_num": "1",
    "steps.step1_title": "Set Up Your Business",
    "steps.step1_desc": "Add your products, pricing, FAQs, and brand voice",
    "steps.step2_num": "2",
    "steps.step2_title": "Connect Your Channels",
    "steps.step2_desc":
      "Connect LINE OA, Facebook Messenger, Website and/or Instagram that you're already selling on",
    "steps.step3_num": "3",
    "steps.step3_title": "Launch & Start Selling",
    "steps.step3_desc":
      "DealDroid works 24/7 following your rules. Your team steps in only when needed",
    "steps.worry_heading": "Worried about setup?",
    "steps.worry_desc":
      "No problem! Our AI Expert team handles the entire setup with you — hands-on until you're live and selling.",
    "steps.worry_cta": "Get Free Inbox Audit",
    "steps.worry_link": config.retail.register.en,
  },
  th: {
    "steps.heading": "เริ่มใช้ง่าย AI เริ่มรับลูกค้าภายใน 48 ชั่วโมง",
    "steps.step1_num": "1",
    "steps.step1_title": "Setup Business",
    "steps.step1_desc": "เพิ่มสินค้า ราคา FAQs และ Brand Voice",
    "steps.step2_num": "2",
    "steps.step2_title": "Connect Channels",
    "steps.step2_desc":
      "เชื่อมต่อ LINE OA, Facebook Messenger, Website และ/หรือ Instagram ที่คุณขายอยู่แล้ว",
    "steps.step3_num": "3",
    "steps.step3_title": "Launch & Sell",
    "steps.step3_desc":
      "DealDroid ทำงาน 24/7 ตามกฎของคุณ ทีมเข้ามาช่วยเฉพาะเมื่อจำเป็น",
    "steps.worry_heading": "กลัว Setup ไม่เป็น?",
    "steps.worry_desc":
      "ไม่มีปัญหา! ทีมงาน AI Expert พร้อม Setup ให้แบบจับมือทำไปด้วยกัน จนเปิดขายได้",
    "steps.worry_cta": "นัดคุยวิเคราะห์ Inbox ฟรี",
    "steps.worry_link": config.retail.register.th,
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);

const steps = [
  {
    num: p("steps.step1_num"),
    title: p("steps.step1_title"),
    desc: p("steps.step1_desc"),
  },
  {
    num: p("steps.step2_num"),
    title: p("steps.step2_title"),
    desc: p("steps.step2_desc"),
  },
  {
    num: p("steps.step3_num"),
    title: p("steps.step3_title"),
    desc: p("steps.step3_desc"),
  },
];
---

<section class="py-16 bg-white">
  <Container>
    <h2 class="text-3xl md:text-4xl font-bold text-center text-slate-900 mb-12">
      {p("steps.heading")}
    </h2>

    <!-- 3 Steps -->
    <div class="grid md:grid-cols-3 gap-8 mb-12 max-w-4xl mx-auto relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-7 left-[calc(16.67%+28px)] right-[calc(16.67%+28px)] h-0.5 bg-indigo-200"></div>
      {
        steps.map((step) => (
          <div class="text-center relative z-10">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-indigo-100 border-2 border-indigo-600 text-indigo-600 font-bold text-xl mb-4">
              {step.num}
            </div>
            <h3 class="font-bold text-slate-900 mb-2">{step.title}</h3>
            <p class="text-base text-slate-600">{step.desc}</p>
          </div>
        ))
      }
    </div>

    <!-- Worry? Box -->
    <div
      class="bg-indigo-50 border-2 border-indigo-200 rounded-2xl p-8 max-w-2xl mx-auto text-center">
      <h3 class="text-lg font-bold text-slate-900 mb-3">
        {p("steps.worry_heading")}
      </h3>
      <p class="text-slate-600 mb-6">{p("steps.worry_desc")}</p>
      <Link href={p("steps.worry_link")} size="lg" style="primary">
        {p("steps.worry_cta")}
      </Link>
    </div>
  </Container>
</section>
