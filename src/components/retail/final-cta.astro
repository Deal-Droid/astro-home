---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import { usePageTranslations } from "../../i18n/utils";
import type { UILanguages } from "../../i18n/ui";
import { config } from "../../config";
import lineSvg from "@assets/channels/line.svg";

const page_ui: UILanguages = {
  en: {
    "fcta.pre_heading":
      "Every day your admin is still slow to respond, you're paying for Ads that will never return",
    "fcta.heading": "Ready to stop losing revenue to slow chat responses?",
    "fcta.desc":
      "Book a free 30-minute Inbox Audit — we'll analyze your inbox, show you where you're losing sales, map out a clear AI strategy, and demo success stories like DJI13Store.",
    "fcta.primary_btn": "Get Free Inbox Audit",
    "fcta.secondary_text": "Chat on LINE First",
    "fcta.trust":
      "✨ Free inbox analysis · No commitment · Go live in 48 hours",
    "fcta.scarcity": "Limited spots · Only 3 brands accepted this week",
    "fcta.primary_link": config.retail.register.en,
    "fcta.secondary_link": config.retail.line,
  },
  th: {
    "fcta.pre_heading":
      "ในทุกวันที่ Admin ยังตอบช้า คุณกำลังจ่ายเงินค่า Ads เสียไปแบบไม่มีวันหวนคืน",
    "fcta.heading": "พร้อมเสริมกำลังให้ทีมแอดมินแล้วหรือยัง?",
    "fcta.desc":
      "นัดคุยกับเราได้ ฟรี — เราจะช่วยสร้าง AI ไปด้วยกัน พร้อมวางแผนการใช้ AI ที่ชัดเจนสำหรับธุรกิจของคุณ",
    "fcta.primary_btn": "นัดคุยเลย",
    "fcta.secondary_text": "คุยทาง LINE ก่อน",
    "fcta.trust":
      "✨ วิเคราะห์การตอบแชทให้ฟรี · ไม่มีข้อผูกมัด · Live ได้ใน 48 ชั่วโมงหลังตัดสินใจ",
    "fcta.scarcity": "รับจำนวนจำกัด · สัปดาห์นี้รับไม่เกิน 3 แบรนด์",
    "fcta.primary_link": config.retail.register.th,
    "fcta.secondary_link": config.retail.line,
  },
} as const;

const lang = Astro.currentLocale || "en";
const p = usePageTranslations(lang, page_ui);
---

<section
  class="py-16 text-white overflow-hidden"
  style="background-image: radial-gradient(circle at 50% 0%, #1E2A4A 0%, #3B3794 99%, #4D5FD0 100%)">
  <Container>
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-indigo-200 text-sm font-medium mb-4">
        {p("fcta.pre_heading")}
      </p>
      <h2
        class="text-3xl md:text-4xl font-bold leading-[1.4] md:leading-[1.4] mb-4">
        {p("fcta.heading")}
      </h2>
      <p class="text-indigo-100 mb-8 text-lg">{p("fcta.desc")}</p>

      <!-- Buttons -->
      <div
        class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-8">
        <Link href={p("fcta.primary_link")} size="lg" style="inverted">
          {p("fcta.primary_btn")}
        </Link>
        <Link
          href={p("fcta.secondary_link")}
          size="lg"
          style="ghost"
          class="inline-flex items-center gap-2">
          <img src={lineSvg.src} alt="LINE" class="w-5 h-5" />
          {p("fcta.secondary_text")}
        </Link>
      </div>

      <!-- Divider + Trust -->
      <div class="border-t border-white/20 pt-6 mb-4">
        <p class="text-indigo-100 text-sm">{p("fcta.trust")}</p>
      </div>

      <!-- Scarcity -->
      <p class="text-indigo-200 text-xs font-semibold uppercase tracking-wider">
        {p("fcta.scarcity")}
      </p>
    </div>
  </Container>
</section>
