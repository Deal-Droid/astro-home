---
import Link from "./ui/link.astro";

import { useTranslations, usePageTranslations } from "../i18n/utils";
import { config } from "../config.ts";

import type { UILanguages } from "../i18n/ui";

const page_ui: UILanguages = {
  en: {
    "cta.h1": "Ready to grow without more hiring?",
    "cta.description":
      "See how Dealdroid can handle your customer conversations and close more deals — without adding staff.",
    "cta.primary": "Book a Demo",
    "cta.primary_link": config.retail.register.en,
    "cta.secondary": "Try it for free",
    "cta.secondary_link": config.urls.register,
  },
  th: {
    "cta.h1": "พร้อมขยายธุรกิจโดยไม่ต้องจ้างคนเพิ่ม?",
    "cta.description":
      "ดูว่า Dealdroid จะช่วยจัดการการสนทนากับลูกค้าและปิดการขายได้มากขึ้นอย่างไร — โดยไม่ต้องเพิ่มพนักงาน",
    "cta.primary": "นัดคุยปรึกษา ฟรี",
    "cta.primary_link": config.retail.register.th,
    "cta.secondary": "ทดลองใช้งานฟรี",
    "cta.secondary_link": config.urls.register,
  },
} as const;

const lang = Astro.currentLocale || "en";
const t = useTranslations(lang);
const p = usePageTranslations(lang, page_ui);
---

<div
  class="bg-gradient-to-bl from-indigo-900 to-indigo-700 p-8 md:px-20 md:py-20 mt-20 flex flex-col items-center text-center">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight">
    {p("cta.h1")}
  </h2>
  <p class="text-white/70 mt-4 text-lg md:text-xl">
    {p("cta.description")}
  </p>
  <div class="flex flex-col sm:flex-row gap-3 mt-5">
    <Link href={p("cta.primary_link")} style="inverted">{p("cta.primary")}</Link
    >
    <Link href={p("cta.secondary_link")} style="ghost"
      >{p("cta.secondary")}</Link
    >
  </div>
</div>
