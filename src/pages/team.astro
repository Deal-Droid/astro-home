---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import TeamGrid from "@components/team-grid.astro";
import Cta from "@components/cta.astro";
---

<Layout title="Team" footerMargin={false}>
  <Container>
    <Sectionhead>
      <Fragment slot="badge">THE TEAM</Fragment>
      <Fragment slot="title">5 people. One mission.</Fragment>
      <Fragment slot="desc">Make AI sell for you.</Fragment>
    </Sectionhead>

    <TeamGrid />
  </Container>

  <Cta />
</Layout>
