---
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/navbar/navbar.astro";
import Hero from "@components/home/hero.astro";
import ClientLogos from "@components/retail/client-logos.astro";
import PainToSolution from "@components/home/pain-to-solution.astro";
import UseCases from "@components/home/use-cases.astro";
import CaseStudy from "@components/home/case-study.astro";
import FinalCta from "@components/retail/final-cta.astro";
import VideoIntro from "@components/home/video-intro.astro";
---

<Layout
  title="AI ตอบแชทแทน Admin สำหรับร้านค้า | DealDroid"
  description="ให้ DealDroid AI ตอบแชทแทน Admin ของคุณ ตอบทันที 24 ชั่วโมง ปิดการขายให้ รองรับแชทพุ่ง วิเคราะห์ Inbox ฟรีสำหรับร้านค้าออนไลน์"
  footerMargin={false}
  navbar={Navbar}>
  <Hero />
  <ClientLogos />
  <PainToSolution />
  <UseCases />
  <CaseStudy />
  <VideoIntro />
  <FinalCta />
</Layout>
