---
import Layout from "@layouts/Layout.astro";
import RetailNavbar from "@components/retail/navbar.astro";
import Hero from "@components/retail/hero.astro";
import ClientLogos from "@components/retail/client-logos.astro";
import PainPoints from "@components/retail/pain-points.astro";
import Bridge from "@components/retail/bridge.astro";
import Solution from "@components/retail/solution.astro";
import UseCases from "@components/retail/use-cases.astro";
import CaseStudy from "@components/retail/case-study.astro";
import FeaturesGrid from "@components/retail/features-grid.astro";
import Steps from "@components/retail/steps.astro";
import Audience from "@components/retail/audience.astro";
import Testimonial from "@components/retail/testimonial.astro";
import BuiltBy from "@components/retail/built-by.astro";
import RetailFaq from "@components/retail/faq.astro";
import FinalCta from "@components/retail/final-cta.astro";
---

<Layout
  title="AI ตอบแชทแทน Admin สำหรับร้านค้า | DealDroid"
  footerMargin={false}
  navbar={RetailNavbar}>
  <Hero />
  <ClientLogos />
  <PainPoints />
  <Bridge />
  <Solution />
  <UseCases />
  <CaseStudy />
  <FeaturesGrid />
  <Steps />
  <Audience />
  <Testimonial />
  <BuiltBy />
  <RetailFaq />
  <FinalCta />
</Layout>
